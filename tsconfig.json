{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@alifarooq/result-kit": ["./src/index.ts"],
      "@alifarooq/result-kit/core": ["./src/core/index.ts"],
      "@alifarooq/result-kit/nest": ["./src/nest/index.ts"]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "verbatimModuleSyntax": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["src", "test", "examples", "vitest.config.ts", "tsdown.config.ts"]
}
