{
  "name": "@zireal/result-kit",
  "version": "3.0.0",
  "description": "Type-safe result and structured error utilities for TypeScript, with optional NestJS adapters.",
  "license": "MIT",
  "author": "Ali Farooq <alifarooq122@gmail.com>",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alifarooq-zk/result-kit.git"
  },
  "keywords": [
    "result",
    "error-handling",
    "result-type",
    "result monad"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist coverage",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepack": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:cov": "vitest run --coverage",
    "check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@nestjs/common": "^11.1.17",
    "@types/node": "^22.19.15",
    "publint": "^0.3.18",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "import": "./dist/core/index.mjs",
      "require": "./dist/core/index.cjs"
    },
    "./nest": {
      "import": "./dist/nest/index.mjs",
      "require": "./dist/nest/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
